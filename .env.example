# ===== TELEGRAM =====
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321  # Через запятую, без пробелов

# ===== DATABASE =====
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpn_bot

# ===== 3X-UI =====
XUI_HOST=https://your-server.com:2053
XUI_TOKEN=your_token
XUI_INBOUND_ID=1  # ID inbound в 3x-ui (VLESS+WS+TLS)

# ===== YOOKASSA =====
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_RETURN_URL=https://t.me/your_bot

# ===== CRYPTOBOT =====
CRYPTOBOT_API_TOKEN=your_cryptobot_token
CRYPTOBOT_NETWORK=mainnet  # mainnet или testnet

# ===== PRICES =====
PRICE_1_MONTH=299  # в рублях

# ===== REFERRAL =====
REFERRAL_REWARD_RUB=50       # Рублей рефереру за каждого реферала
REFERRAL_DISCOUNT_PERCENT=50  # Скидка рефералу на первую покупку

# ===== NOTIFICATIONS =====
NOTIFY_BEFORE_DAYS=3  # За сколько дней предупреждать об окончании
